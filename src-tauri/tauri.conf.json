{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zplayer",
  "version": "0.1.0",
  "identifier": "com.li.zplayer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5175",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "create": false,
        "title": "zplayer",
        "width": 1440,
        "height": 900,
        "minWidth": 1040,
        "minHeight": 720,
        "transparent": true,
        "backgroundColor": "#050505",
        "shadow": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../libmpv/**/*"
    ]
  }
}
